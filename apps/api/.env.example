DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"
JWT_SECRET="<min 32 chars>"
JWT_REFRESH_SECRET="<min 32 chars>"
GEMINI_API_KEY="AIza..."
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_USER="<ethereal user>"
SMTP_PASS="<ethereal pass>"
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"
PORT="3001"
# IANA id for the timezone your CSV wall times are in (e.g. US Eastern exports → America/New_York; handles EST and EDT)
# Default when unset/invalid: UTC
ANALYTICS_TIMEZONE="America/New_York"
# Pipeline logging (pino): fatal | error | warn | info | debug | trace | silent
LOG_LEVEL="info"
ADMIN_EMAIL="admin@test.com"
